# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Required: used to encrypt saved credentials. Set to any random string.
N8N_ENCRYPTION_KEY=change-me

# n8n API key — generate one in n8n under Settings → API → Create API Key.
N8N_API_KEY=

# Enterspeed demo tenant API keys (ask the team for these).
ENTERSPEED_SOURCE_API_KEY=
ENTERSPEED_ENVIRONMENT_API_KEY=
