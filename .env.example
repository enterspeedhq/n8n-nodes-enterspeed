# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Required: used to encrypt saved credentials. Set to any random string.
N8N_ENCRYPTION_KEY=change-me

# Optional: pre-configure the n8n owner account on first run.
# If set, n8n skips the setup wizard. Required for CI.
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=

# Enterspeed demo tenant API keys (ask the team for these).
ENTERSPEED_SOURCE_API_KEY=
ENTERSPEED_ENVIRONMENT_API_KEY=
